// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id                    Int      @id @default(autoincrement())
  customer_name         String
  address              String?
  ntn                  String?
  sales_tax_registration String?
  vendor_code           String?
  phone                String?
  created_at           DateTime @default(now())
  purchase_orders      PurchaseOrder[]
  challans             Challan[]
  invoices             Invoice[]
  warranties           Warranty[]
  payments             Payment[]
}

model Product {
  id           Int      @id @default(autoincrement())
  product_name String
  product_code String   @unique
  unit_price   Float
  created_at   DateTime @default(now())
  po_items     POItem[]
  production   ProductionTracking[]
  challan_items ChallanItem[]
  deliveries   Delivery[]
  invoice_items InvoiceItem[]
}

model PurchaseOrder {
  id           Int      @id @default(autoincrement())
  po_number    String   @unique
  customer_id  Int
  customer     Customer @relation(fields: [customer_id], references: [id])
  po_date      DateTime
  due_date     DateTime
  status       String   // Pending / In Progress / Completed
  gst_percentage Float  @default(18.0)
  created_at   DateTime @default(now())
  items        POItem[]
  production   ProductionTracking[]
  challans     Challan[]
  deliveries   Delivery[]
  invoices     Invoice[]
  warranties   Warranty[]
}

model POItem {
  id           Int           @id @default(autoincrement())
  po_id        Int
  po           PurchaseOrder @relation(fields: [po_id], references: [id])
  product_id   Int
  product      Product       @relation(fields: [product_id], references: [id])
  quantity     Int
  rate         Float
  total_amount Float
}

model ProductionTracking {
  id           Int           @id @default(autoincrement())
  po_id        Int
  po           PurchaseOrder @relation(fields: [po_id], references: [id])
  product_id   Int
  product      Product       @relation(fields: [product_id], references: [id])
  ordered_qty  Int
  delivered_qty Int          @default(0)
  rejected_qty Int          @default(0)
  pending_qty  Int          // Ordered - Delivered - Rejected
  status       String
  last_updated DateTime      @updatedAt
}

model Challan {
  id           Int           @id @default(autoincrement())
  gdn_number   String        @unique
  po_id        Int
  po           PurchaseOrder @relation(fields: [po_id], references: [id])
  challan_date DateTime
  customer_id  Int
  customer     Customer      @relation(fields: [customer_id], references: [id])
  status       String
  items        ChallanItem[]
}

model ChallanItem {
  id           Int      @id @default(autoincrement())
  challan_id   Int
  challan      Challan  @relation(fields: [challan_id], references: [id])
  product_id   Int
  product      Product  @relation(fields: [product_id], references: [id])
  delivered_qty Int
  remarks      String?
}

model Delivery {
  id           Int           @id @default(autoincrement())
  po_id        Int
  po           PurchaseOrder @relation(fields: [po_id], references: [id])
  product_id   Int
  product      Product       @relation(fields: [product_id], references: [id])
  delivered_qty Int
  delivery_date DateTime
  invoice_id   Int?
  invoice      Invoice?      @relation(fields: [invoice_id], references: [id])
}

model Invoice {
  id             Int           @id @default(autoincrement())
  invoice_number String        @unique
  customer_id    Int
  customer       Customer      @relation(fields: [customer_id], references: [id])
  po_id          Int
  po             PurchaseOrder @relation(fields: [po_id], references: [id])
  invoice_date   DateTime
  subtotal       Float
  gst_amount     Float
  total_amount   Float
  status         String
  items          InvoiceItem[]
  deliveries     Delivery[]
  sales_tax_info SalesTaxInvoice?
  warranties     Warranty[]
  payments       Payment[]
}

model InvoiceItem {
  id           Int      @id @default(autoincrement())
  invoice_id   Int
  invoice      Invoice  @relation(fields: [invoice_id], references: [id])
  product_id   Int
  product      Product  @relation(fields: [product_id], references: [id])
  quantity     Int
  rate         Float
  amount       Float
}

model SalesTaxInvoice {
  id             Int      @id @default(autoincrement())
  invoice_id     Int      @unique
  invoice        Invoice  @relation(fields: [invoice_id], references: [id])
  gst_percentage Float
  gst_amount     Float
  total_with_tax Float
}

model Warranty {
  id              Int           @id @default(autoincrement())
  warranty_number String        @unique
  customer_id     Int
  customer        Customer      @relation(fields: [customer_id], references: [id])
  invoice_id      Int?
  invoice         Invoice?      @relation(fields: [invoice_id], references: [id])
  po_id           Int?
  po              PurchaseOrder? @relation(fields: [po_id], references: [id])
  start_date      DateTime
  end_date        DateTime
  status          String
  terms           String?
  created_at      DateTime      @default(now())
}

model Payment {
  id             Int      @id @default(autoincrement())
  customer_id    Int
  customer       Customer @relation(fields: [customer_id], references: [id])
  invoice_id     Int
  invoice        Invoice  @relation(fields: [invoice_id], references: [id])
  payment_date   DateTime
  amount_paid    Float
  payment_method String
  wht_amount     Float    @default(0)
  retained_amount Float   @default(0)
  ld_penalty     Float    @default(0)
  remarks        String?
}
